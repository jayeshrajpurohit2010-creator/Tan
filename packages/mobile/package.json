{
  "name": "@tan/mobile",
  "version": "1.0.0",
  "description": "Tan Forensic Archival Suite — Android mobile app",
  "main": "index.js",
  "private": true,
  "scripts": {
    "android":        "react-native run-android",
    "ios":            "react-native run-ios",
    "start":          "react-native start",
    "build:android":  "react-native build-android --mode=release",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle",
    "test":           "jest",
    "typecheck":      "tsc --noEmit"
  },
  "dependencies": {
    "@tan/shared":                      "*",
    "react":                            "18.2.0",
    "react-native":                     "0.73.6",
    "react-native-webview":             "^13.8.6",
    "react-native-fs":                  "^2.20.0",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "react-native-linear-gradient":     "^2.8.3",
    "react-native-svg":                 "^15.2.0",
    "@react-navigation/native":         "^6.1.17",
    "@react-navigation/stack":          "^6.3.29",
    "react-native-screens":             "^3.29.0",
    "react-native-safe-area-context":   "^4.10.1",
    "react-native-gesture-handler":     "^2.16.2",
    "react-native-reanimated":          "^3.10.1"
  },
  "devDependencies": {
    "@babel/core":              "^7.20.0",
    "@babel/preset-env":        "^7.20.0",
    "@babel/runtime":           "^7.20.0",
    "@react-native/babel-preset": "0.73.21",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.5",
    "@react-native/typescript-config": "0.73.1",
    "@types/react":             "^18.2.6",
    "@types/react-native":      "^0.72.8",
    "typescript":               "5.0.4"
  },
  "jest": {
    "preset": "react-native"
  },
  "engines": {
    "node": ">=18"
  }
}
